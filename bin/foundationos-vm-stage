#!/bin/bash

set -eEo pipefail
source "$(dirname "$0")/foundationos-env"

target_dir="${FOUNDATIONOS_VM_TARGET:-$HOME/.local/share/foundationos-vm}"
upstream_repo="https://github.com/basecamp/omarchy.git"
upstream_ref="$FOUNDATIONOS_UPSTREAM_BRANCH"
from_local=""
run_install=false

ref_exists() {
  local repo_dir="$1"
  local ref_name="$2"

  git -C "$repo_dir" show-ref --verify --quiet "refs/heads/$ref_name" \
    || git -C "$repo_dir" show-ref --verify --quiet "refs/remotes/origin/$ref_name" \
    || git -C "$repo_dir" show-ref --verify --quiet "refs/remotes/upstream/$ref_name"
}

checkout_ref() {
  local repo_dir="$1"
  local ref_name="$2"

  if git -C "$repo_dir" show-ref --verify --quiet "refs/heads/$ref_name"; then
    git -C "$repo_dir" checkout "$ref_name"
    return 0
  fi

  if git -C "$repo_dir" show-ref --verify --quiet "refs/remotes/origin/$ref_name"; then
    git -C "$repo_dir" checkout -B "$ref_name" "origin/$ref_name"
    return 0
  fi

  if git -C "$repo_dir" show-ref --verify --quiet "refs/remotes/upstream/$ref_name"; then
    git -C "$repo_dir" checkout -B "$ref_name" "upstream/$ref_name"
    return 0
  fi

  return 1
}

checkout_default_branch() {
  local repo_dir="$1"
  local remote_head

  remote_head="$(git -C "$repo_dir" symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)"

  if [[ -n $remote_head ]]; then
    git -C "$repo_dir" checkout -B "${remote_head#origin/}" "$remote_head"
    return 0
  fi

  foundationos::warn "Unable to determine origin HEAD for $repo_dir. Keeping current checkout."
  return 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --target)
      target_dir="$2"
      shift 2
      ;;
    --upstream-repo)
      upstream_repo="$2"
      shift 2
      ;;
    --upstream-ref)
      upstream_ref="$2"
      shift 2
      ;;
    --from-local)
      from_local="$2"
      shift 2
      ;;
    --run-install)
      run_install=true
      shift
      ;;
    *)
      foundationos::die "Unknown argument: $1"
      ;;
  esac
done

if ! foundationos::has_cmd git; then
  foundationos::die "git is required to stage the upstream desktop base."
fi

if ! foundationos::has_cmd rsync; then
  foundationos::die "rsync is required to stage the upstream desktop base."
fi

if [[ -d $target_dir/.git ]]; then
  foundationos::log "Refreshing existing VM staging tree at $target_dir"
  git -C "$target_dir" fetch --all --tags || true
else
  rm -rf "$target_dir"
  if [[ -n $from_local ]]; then
    foundationos::log "Cloning local upstream checkout from $from_local"
    git clone "$from_local" "$target_dir"
  else
    foundationos::log "Cloning upstream desktop base from $upstream_repo"
    git clone --depth 1 --branch "$upstream_ref" "$upstream_repo" "$target_dir"
  fi
fi

if ! checkout_ref "$target_dir" "$upstream_ref"; then
  foundationos::warn "Requested upstream ref '$upstream_ref' is unavailable in $target_dir."
  checkout_default_branch "$target_dir" || true
fi

current_branch="$(git -C "$target_dir" branch --show-current 2>/dev/null || true)"
if [[ -n $current_branch ]]; then
  git -C "$target_dir" pull --ff-only || true
fi

for stage in preflight packaging config login post-install; do
  upstream_all="$target_dir/install/$stage/all.sh"
  backup_all="$target_dir/install/$stage/upstream.sh"

  if [[ -f $upstream_all && ! -f $backup_all ]]; then
    cp "$upstream_all" "$backup_all"
  fi
done

rsync -a --exclude='.git' "$FOUNDATIONOS_ROOT"/ "$target_dir"/

cat > "$target_dir/.foundationos-overlay" <<EOF
FOUNDATIONOS_SOURCE_ROOT=$FOUNDATIONOS_ROOT
FOUNDATIONOS_OVERLAY_APPLIED_AT=$(date -u +%Y-%m-%dT%H:%M:%SZ)
FOUNDATIONOS_UPSTREAM_REPO=$upstream_repo
FOUNDATIONOS_UPSTREAM_REF=$upstream_ref
EOF

foundationos::log "FoundationOS VM tree staged at $target_dir"
foundationos::info "Run FOUNDATIONOS_ROOT=$target_dir FOUNDATIONOS_PATH=$target_dir bash $target_dir/install.sh inside an Arch VM."

if [[ $run_install == true ]]; then
  FOUNDATIONOS_ROOT="$target_dir" FOUNDATIONOS_PATH="$target_dir" bash "$target_dir/install.sh"
fi
