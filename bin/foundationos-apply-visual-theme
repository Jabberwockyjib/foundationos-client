#!/bin/bash

set -eEo pipefail
source "$(dirname "$0")/foundationos-env"

theme_name="${1:-foundationos-default}"
theme_dir="$HOME/.config/omarchy/themes/$theme_name"

if ! foundationos::has_cmd omarchy-theme-set; then
  foundationos::die "omarchy-theme-set is not available on this workstation."
fi

if [[ ! -d $theme_dir ]]; then
  foundationos::die "FoundationOS theme assets are missing at $theme_dir"
fi

omarchy-theme-set "$theme_name"
