#!/bin/bash

set -eEo pipefail

FOUNDATIONOS_BIN_DIR="$(cd -- "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck disable=SC1091
source "$FOUNDATIONOS_BIN_DIR/../lib/foundationos.sh"
foundationos::load_env

if [[ ${BASH_SOURCE[0]} == "$0" ]]; then
  cat <<EOF
FOUNDATIONOS_ROOT=$FOUNDATIONOS_ROOT
FOUNDATIONOS_CONFIG=$FOUNDATIONOS_CONFIG
FOUNDATIONOS_STATE_DIR=$FOUNDATIONOS_STATE_DIR
FOUNDATIONOS_CHANNEL=$FOUNDATIONOS_CHANNEL
FOUNDATIONOS_RELEASE_ID=$FOUNDATIONOS_RELEASE_ID
FOUNDATION_BASE_URL=$FOUNDATION_BASE_URL
FOUNDATION_API_BASE_URL=$FOUNDATION_API_BASE_URL
FOUNDATION_AGENT_SERVICE=$FOUNDATION_AGENT_SERVICE
FREEIPA_SERVER=$FREEIPA_SERVER
ROLE_BUNDLE=$(foundationos::role_bundle_from_groups)
EOF
fi
