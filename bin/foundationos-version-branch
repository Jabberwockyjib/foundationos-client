#!/bin/bash

set -eEo pipefail
source "$(dirname "$0")/foundationos-env"

if git -C "$FOUNDATIONOS_PATH" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  git -C "$FOUNDATIONOS_PATH" branch --show-current
elif git -C "$FOUNDATIONOS_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  git -C "$FOUNDATIONOS_ROOT" branch --show-current
else
  echo "${FOUNDATIONOS_FORK_BRANCH:-main}"
fi
