#!/bin/bash

set -eEo pipefail
source "$(dirname "$0")/foundationos-env"
source "$FOUNDATIONOS_ROOT/lib/foundationos-ui.sh"

selection="$(
  foundationos::ui::menu "FoundationOS" $'Foundation Launcher\nFoundation Pulse\nFoundation Chat\nFoundation Approvals\nFoundation Flows\nApplication Launcher\nWorkstation Setup\nDesktop Style\nClient Update\nAbout Workstation\nPower\nDiagnostics'
)"

case "$selection" in
  "Foundation Launcher")
    "$FOUNDATIONOS_ROOT/bin/foundationos-launcher"
    ;;
  "Foundation Pulse")
    "$FOUNDATIONOS_ROOT/bin/foundationos-open-link" foundation://pulse
    ;;
  "Foundation Chat")
    "$FOUNDATIONOS_ROOT/bin/foundationos-open-link" foundation://chat
    ;;
  "Foundation Approvals")
    "$FOUNDATIONOS_ROOT/bin/foundationos-open-link" foundation://approvals
    ;;
  "Foundation Flows")
    "$FOUNDATIONOS_ROOT/bin/foundationos-open-link" foundation://flows
    ;;
  "Application Launcher")
    if foundationos::has_cmd omarchy-launch-walker; then
      omarchy-launch-walker -p "Launch…"
    else
      "$FOUNDATIONOS_ROOT/bin/foundationos-launcher"
    fi
    ;;
  "Workstation Setup")
    "$FOUNDATIONOS_ROOT/bin/foundationos-workstation-menu" setup
    ;;
  "Desktop Style")
    "$FOUNDATIONOS_ROOT/bin/foundationos-workstation-menu" style
    ;;
  "Client Update")
    "$FOUNDATIONOS_ROOT/bin/foundationos-workstation-menu" update
    ;;
  "About Workstation")
    "$FOUNDATIONOS_ROOT/bin/foundationos-workstation-menu" about
    ;;
  "Power")
    "$FOUNDATIONOS_ROOT/bin/foundationos-workstation-menu" system
    ;;
  "Diagnostics")
    foundationos::launch_terminal "foundationos-diagnostics; printf '\nPress Enter to close...'; read -r _"
    ;;
  "")
    ;;
  *)
    foundationos::warn "Unhandled FoundationOS menu selection: $selection"
    ;;
esac
