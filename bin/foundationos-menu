#!/bin/bash

set -eEo pipefail
source "$(dirname "$0")/foundationos-env"

prompt_menu() {
  local prompt="$1"

  if foundationos::has_cmd walker; then
    walker --dmenu -p "$prompt"
    return 0
  fi

  if foundationos::has_cmd rofi; then
    rofi -dmenu -p "$prompt"
    return 0
  fi

  if foundationos::has_cmd wofi; then
    wofi --dmenu --prompt "$prompt"
    return 0
  fi

  foundationos::die "No supported launcher is available. Install Walker, Rofi, or Wofi."
}

selection="$(
  printf '%s\n' \
    "Foundation Launcher" \
    "Foundation Pulse" \
    "Foundation Chat" \
    "Foundation Approvals" \
    "Foundation Flows" \
    "Application Launcher" \
    "Setup" \
    "Style" \
    "System" \
    "Update Plan" \
    "Diagnostics" \
    | prompt_menu "FoundationOS"
)"

case "$selection" in
  "Foundation Launcher")
    "$FOUNDATIONOS_ROOT/bin/foundationos-launcher"
    ;;
  "Foundation Pulse")
    "$FOUNDATIONOS_ROOT/bin/foundationos-open-link" foundation://pulse
    ;;
  "Foundation Chat")
    "$FOUNDATIONOS_ROOT/bin/foundationos-open-link" foundation://chat
    ;;
  "Foundation Approvals")
    "$FOUNDATIONOS_ROOT/bin/foundationos-open-link" foundation://approvals
    ;;
  "Foundation Flows")
    "$FOUNDATIONOS_ROOT/bin/foundationos-open-link" foundation://flows
    ;;
  "Application Launcher")
    if foundationos::has_cmd omarchy-launch-walker; then
      omarchy-launch-walker -p "Launch…"
    else
      "$FOUNDATIONOS_ROOT/bin/foundationos-launcher"
    fi
    ;;
  "Setup")
    foundationos::has_cmd omarchy-menu && omarchy-menu setup
    ;;
  "Style")
    foundationos::has_cmd omarchy-menu && omarchy-menu style
    ;;
  "System")
    foundationos::has_cmd omarchy-menu && omarchy-menu system
    ;;
  "Update Plan")
    foundationos::launch_terminal "foundationos-update plan; printf '\nPress Enter to close...'; read -r _"
    ;;
  "Diagnostics")
    foundationos::launch_terminal "foundationos-diagnostics; printf '\nPress Enter to close...'; read -r _"
    ;;
  "")
    ;;
  *)
    foundationos::warn "Unhandled FoundationOS menu selection: $selection"
    ;;
esac
