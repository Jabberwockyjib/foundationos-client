{
  "custom/foundation": {
    "format": "{}",
    "tooltip": true,
    "on-click": "foundationos-launcher",
    "on-click-middle": "foundationos-launch-foundation pulse",
    "on-click-right": "foundationos-launcher",
    "return-type": "json",
    "exec": "foundationos-waybar",
    "interval": 30
  }
}
