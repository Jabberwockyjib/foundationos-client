#!/bin/bash

set -eEo pipefail

repo_dir="/opt/foundationos-client"
live_config="/etc/foundationos-live.conf"
release_file="/etc/foundationos-release.env"

prepare_user() {
  local user_name="$1"
  local home_dir="$2"

  [[ -d $home_dir ]] || return 0

  mkdir -p "$home_dir/.config/foundationos"

  if [[ -f $live_config && ! -f $home_dir/.config/foundationos/foundationos.conf ]]; then
    install -m 0644 "$live_config" "$home_dir/.config/foundationos/foundationos.conf"
  fi

  if [[ -f $release_file ]]; then
    install -m 0644 "$release_file" "$home_dir/.config/foundationos/live-release.env"
  fi

  ln -snf "$repo_dir" "$home_dir/foundationos-client"
  chown -h "$user_name:$user_name" "$home_dir/foundationos-client" || true
  chown -R "$user_name:$user_name" "$home_dir/.config/foundationos" || true
}

for home_dir in /home/*; do
  [[ -d $home_dir ]] || continue
  prepare_user "$(basename "$home_dir")" "$home_dir"
done

if [[ -d /root ]]; then
  mkdir -p /root/.config/foundationos
  [[ -f $live_config ]] && install -m 0644 "$live_config" /root/.config/foundationos/foundationos.conf
  [[ -f $release_file ]] && install -m 0644 "$release_file" /root/.config/foundationos/live-release.env
  ln -snf "$repo_dir" /root/foundationos-client
fi
